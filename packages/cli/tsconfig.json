{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@opensecurity/zonzon-core": ["../core/src/index.ts"],
      "@opensecurity/zonzon-control-plane": ["../control-plane/src/index.ts"]
    }
  },
  "references": [
    { "path": "../core" },
    { "path": "../control-plane" }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}