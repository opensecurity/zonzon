{
  "name": "@opensecurity/zonzon-mono",
  "version": "0.1.5",
  "private": true,
  "description": "DNS and HTTP Proxy Infrastructure",
  "type": "module",
  "author": "Lucian BLETAN <neuraluc@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opensecurity/zonzon.git"
  },
  "homepage": "https://github.com/opensecurity/zonzon#readme",
  "bugs": {
    "url": "https://github.com/opensecurity/zonzon/issues"
  },
  "keywords": [
    "zero-trust",
    "dns",
    "proxy",
    "security",
    "firewall",
    "sni",
    "infrastructure"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "node --disable-warning=DEP0205 --import tsx --test \"packages/**/*.test.ts\"",
    "start": "npm start --workspace=@opensecurity/zonzon-cli",
    "dev": "npm run build && npm run dev:watch --workspace=@opensecurity/zonzon-cli",
    "docker:up": "docker compose up",
    "docker:build": "docker build -t zonzon .",
    "clean": "rm -rf packages/*/dist packages/*/tsconfig.tsbuildinfo tsconfig.tsbuildinfo",
    "bump:patch": "node scripts/bump.js patch && npm install",
    "bump:minor": "node scripts/bump.js minor && npm install",
    "bump:major": "node scripts/bump.js major && npm install"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.7.3",
    "tsx": "^4.19.3"
  }
}
