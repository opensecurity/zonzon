{
  "port": 53,
  "httpPort": 80,
  "httpsPort": 443,
  "fallbackDns": "1.1.1.1",
  "controlPlane": {
    "enabled": true,
    "port": 58080
  },
  "firewall": {
    "defaultPolicy": "deny",
    "allowlist_domains": [
      "*.ubuntu.com",
      "ubuntu.com",
      "*.github.com",
      "github.com",
      "*.githubusercontent.com",
      "*.test.local",
      "*.loop"
    ],
    "allowlist_ips": [
      "127.0.0.1"
    ],
    "blocklist_ips": [
      "169.254.169.254"
    ],
    "allowlist_ranges": [
      "0.0.0.0/0",
      "127.0.0.0/8"
    ],
    "blocklist_ranges": [
      "0.0.0.0/8"
    ]
  },
  "hosts": {
    "*": {
      "records": [
        {
          "type": "A",
          "address": "172.20.0.53"
        }
      ]
    },
    "secure.test.local": {
      "records": [
        {
          "type": "A",
          "address": "172.20.0.53"
        }
      ],
      "redirect": {
        "enabled": true,
        "code": 301,
        "target": "https://secure.test.local"
      },
      "tls_proxy": {
        "targetPort": 1235,
        "targetIp": "172.21.0.100"
      }
    },
    "secure-api.loop": {
      "records": [
        {
          "type": "A",
          "address": "172.20.0.53"
        }
      ],
      "http_proxy": {
        "enabled": true,
        "upstream": "https://172.21.0.100:1234",
        "headers": {
          "X-Environment": "sandbox-mtls-verified"
        },
        "clientTls": {
          "cert": "/app/config/client.crt",
          "key": "/app/config/client.key",
          "ca": "/app/config/ca.crt",
          "serverName": "secure.test.local"
        }
      }
    },
    "mock.ai.loop": {
      "records": [
        {
          "type": "A",
          "address": "172.20.0.53"
        }
      ],
      "http_proxy": {
        "enabled": true,
        "upstream": "http://127.0.0.1:3000",
        "headers": {
          "X-Environment": "sandbox-intercept"
        }
      }
    },
    "redirect.loop": {
      "records": [
        {
          "type": "A",
          "address": "0.0.0.0"
        }
      ],
      "redirect": {
        "code": 302,
        "target": "https://github.com/archive/main"
      }
    },
    "test-records.loop": {
      "records": [
        {
          "type": "A",
          "address": "10.0.0.1"
        },
        {
          "type": "AAAA",
          "address": "2001:db8::1"
        },
        {
          "type": "TXT",
          "data": [
            "v=spf1 -all",
            "zonzon-test-string"
          ]
        },
        {
          "type": "MX",
          "priority": 10,
          "exchange": "mail.test-records.loop"
        },
        {
          "type": "NS",
          "target": "ns1.test-records.loop"
        }
      ]
    },
    "cname.test-records.loop": {
      "records": [
        {
          "type": "CNAME",
          "target": "test-records.loop"
        }
      ]
    },
    "_sip._tcp.test-records.loop": {
      "records": [
        {
          "type": "SRV",
          "priority": 10,
          "weight": 5,
          "port": 5060,
          "target": "sip.test-records.loop"
        }
      ]
    },
    "53.0.20.172.in-addr.arpa": {
      "records": [
        {
          "type": "PTR",
          "target": "zonzon.sandbox.local"
        }
      ]
    }
  }
}