FROM ubuntu:rolling

RUN apt-get update -qq && \
    apt-get install -y -qq curl dnsutils ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Import the Custom CA generated by tests/nginx/generate-certs.sh
COPY tests/nginx/certs/custom-ca.crt /usr/local/share/ca-certificates/custom-ca.crt
RUN update-ca-certificates

CMD ["sleep", "infinity"]